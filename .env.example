# EmailJS Configuration
# Get these values from https://www.emailjs.com/

# Your EmailJS Public Key (available in EmailJS dashboard Settings > API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your EmailJS Service ID (created in Services section)
VITE_EMAILJS_SERVICE_ID=service_your_service_name

# Your EmailJS Template ID (created in Email Templates section)
VITE_EMAILJS_TEMPLATE_ID=template_your_template_name
